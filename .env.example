# Copy to .env in this folder (local dev). Production: set the same keys in your host’s dashboard.

# --- Vite (local QR designer) ---
# Point to your hosted tracking API (no trailing slash). Then run `npm run dev` and Register
# uses that API; the QR encodes that origin + /t/… . Omit to use the Vite proxy (needs dev:full).
# VITE_TRACKING_API_URL=https://your-name.onrender.com

# --- SMTP: Gmail ---
# 1) Use your full Gmail address for SMTP_USER.
# 2) Do NOT use your normal Google password. Create an "App password":
#    Google Account → Security → 2-Step Verification (must be ON) → App passwords
#    → create one for "Mail" / "Other" and paste the 16-character password as SMTP_PASS.
# 3) Typical Gmail settings (STARTTLS on 587; leave SMTP_SECURE=false)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=QR Studio <you@gmail.com>

# Optional: use port 465 with implicit TLS
# SMTP_PORT=465
# SMTP_SECURE=true

# Server port (default 3000)
# PORT=3000

# Minimum milliseconds between scan emails for the same link (default 60000)
# SCAN_EMAIL_THROTTLE_MS=60000

# --- Telegram (optional alternative to email) ---
# 1) Open @BotFather on Telegram → /newbot → copy the HTTP API token.
# 2) Put it here. Anyone who knows the token can control the bot, so keep .env private.
# 3) Start a chat with your bot, then get your user id (digits) from @userinfobot and paste
#    it in the app as "Telegram chat id". For a group, add the bot to the group and use the
#    negative group id (some bots report it when added).
TELEGRAM_BOT_TOKEN=

# --- Server: API only (no website UI) ---
# On Render, use Build: `npm install`  Start: `npm run start:api`
# (skip `npm run build` for frontend — not needed when API only)
# Set in dashboard or .env: API_ONLY=1
# API_ONLY=1
